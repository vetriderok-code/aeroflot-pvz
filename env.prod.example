# Production environment variables
# Скопируйте этот файл в .env.prod и заполните значения

# Telegram Bot
TOKEN=your_telegram_bot_token
YANDEX_API_KEY=your_yandex_api_key
# Доп. ключ Geocoder (пробуется первым; основной YANDEX_API_KEY остаётся для карт)
YANDEX_API_KEY_EXTRA=

# Django
SECRET_KEY=your_very_secure_secret_key_here_min_50_chars
DEBUG=False

# Database
PG_LINK=postgresql://rubicon_user:strong_password_here@database:5432/rubicon_db
SQL_ENGINE=django.db.backends.postgresql_psycopg2
DATABASE_TYPE=postgres
POSTGRES_HOST=database
POSTGRES_PORT=5432
POSTGRES_USER=rubicon_user
POSTGRES_PASSWORD=strong_password_here
POSTGRES_DB=rubicon_db

# Redis
REDIS_URL=redis://:strong_redis_password@redis:6379/1
REDIS_PASSWORD=strong_redis_password

# Django Admin
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=strong_admin_password
DJANGO_SUPERUSER_EMAIL=admin@aeroflot-pvz.ru

# Allowed Hosts (важно для продакшна!)
DJANGO_ALLOWED_HOSTS=aeroflot-pvz.ru www.aeroflot-pvz.ru 45.155.52.249

# CSRF и Security
CSRF_TRUSTED_ORIGINS=https://aeroflot-pvz.ru,https://www.aeroflot-pvz.ru
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Keycloak (обновите URL если нужно)
KEYCLOAK_SERVER_URL=https://static.88.68.91.77.ip.webhost1.net
KEYCLOAK_REALM_NAME=Rubik
KEYCLOAK_CLIENT_ID=rubicon-app
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_VERIFY_SSL=False

# Telegram (опционально)
TG_ADMIN=your_telegram_id
TG_GROUP_ID=your_group_id
TG_TOPIC_KT=your_topic_id
TG_TOPIC_ST=your_topic_id
# Группа Старт/Стоп (t.me/c/3960872491 → -1003960872491)
TELEGRAM_LIVE_FLIGHT_CHAT_ID=-1003960872491
TELEGRAM_ALERTS_TOPIC_ID=2408
TELEGRAM_REPORTS_TOPIC_ID=2406
# Секрет для POST /api/live_flight/event/ (тот же в .env бота и Django)
LIVE_FLIGHT_BOT_SECRET=change_me_to_long_random_string
# URL Django для бота (в Docker: http://api:8000, на сервере: http://api:8000 или внутренний адрес)
RUBICON_API_URL=http://api:8000











