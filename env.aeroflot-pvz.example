# aeroflot-pvz.ru — статистика (без Telegram-бота)
# cp env.aeroflot-pvz.example .env && заполните секреты

# Карта: ключ JavaScript API Яндекс.Карт (developer.tech.yandex.ru)
YANDEX_API_KEY=your_yandex_maps_js_api_key
YANDEX_API_KEY_EXTRA=
MAP_GSH_ENABLED=True

SECRET_KEY=change_me_generate_with_python_secrets
DEBUG=False

PG_LINK=postgresql://aeroflot_user:CHANGE_DB_PASS@database:5432/aeroflot_db
SQL_ENGINE=django.db.backends.postgresql_psycopg2
DATABASE_TYPE=postgres
POSTGRES_HOST=database
POSTGRES_PORT=5432
POSTGRES_USER=aeroflot_user
POSTGRES_PASSWORD=CHANGE_DB_PASS
POSTGRES_DB=aeroflot_db

REDIS_URL=redis://:CHANGE_REDIS_PASS@redis:6379/1
REDIS_PASSWORD=CHANGE_REDIS_PASS

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=CHANGE_ADMIN_PASS
DJANGO_SUPERUSER_EMAIL=admin@aeroflot-pvz.ru

DJANGO_ALLOWED_HOSTS=aeroflot-pvz.ru,www.aeroflot-pvz.ru,45.155.52.249

CSRF_TRUSTED_ORIGINS=https://aeroflot-pvz.ru,https://www.aeroflot-pvz.ru
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

KEYCLOAK_SERVER_URL=https://static.88.68.91.77.ip.webhost1.net
KEYCLOAK_REALM_NAME=Rubik
KEYCLOAK_CLIENT_ID=rubicon-app
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_VERIFY_SSL=False

# Импорт Excel (положите файл в /opt/aeroflot-pvz/import/ на сервере)
# FLIGHTS_EXCEL_IMPORT_DIR=/opt/aeroflot-pvz/import
# FLIGHTS_EXCEL_IMPORT_FILENAME=ТАБ_ПИСЬМЕННОГО_ДОКЛАДА_ПИЛОТОВ_НОВАЯ2.xlsm

DASHBOARD_SHIFT_DAY_START_HOUR=6
DASHBOARD_SHIFT_NIGHT_START_HOUR=18

# Оперативный дашборд (/dashboard/, /api/live_dashboard/) — выкл. для aeroflot-pvz
DASHBOARD_ENABLED=False

PORTAL_SITE_NAME=ДНЕПР

# Импорт Excel в фоне (не блокирует сайт при загрузке больших .xlsm)
EXCEL_IMPORT_ASYNC=True
