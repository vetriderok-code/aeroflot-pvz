# Production on airlineportal.ru (NAS 46.150.107.211, TLS via Caddy)

TOKEN=your_telegram_bot_token
YANDEX_API_KEY=your_yandex_api_key
YANDEX_API_KEY_EXTRA=

SECRET_KEY=change_me_generate_with_python_secrets
DEBUG=False

PG_LINK=postgresql://rubicon_user:CHANGE_DB_PASS@database:5432/rubicon_db
SQL_ENGINE=django.db.backends.postgresql_psycopg2
DATABASE_TYPE=postgres
POSTGRES_HOST=database
POSTGRES_PORT=5432
POSTGRES_USER=rubicon_user
POSTGRES_PASSWORD=CHANGE_DB_PASS
POSTGRES_DB=rubicon_db

# Пароль с # % * @ и др. — URL-кодировать (# → %23, % → %25, …)
REDIS_URL=redis://:CHANGE_REDIS_PASS@redis:6379/1
REDIS_PASSWORD=CHANGE_REDIS_PASS

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=CHANGE_ADMIN_PASS
DJANGO_SUPERUSER_EMAIL=admin@airlineportal.ru

DJANGO_ALLOWED_HOSTS=airlineportal.ru www.airlineportal.ru rubicon-api rubicon-gateway 46.150.107.211

CSRF_TRUSTED_ORIGINS=https://airlineportal.ru,https://www.airlineportal.ru
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

KEYCLOAK_SERVER_URL=https://static.88.68.91.77.ip.webhost1.net
KEYCLOAK_REALM_NAME=Rubik
KEYCLOAK_CLIENT_ID=rubicon-app
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_VERIFY_SSL=False

TG_ADMIN=your_telegram_id
# Приватный канал/группа для догрузки (бот — админ). Рабочая группа не используется.
TELEGRAM_BACKFILL_CHAT_ID=
TELEGRAM_BACKFILL_ON_START=false
TELEGRAM_BACKFILL_LIMIT=1500
TG_GROUP_ID=your_group_id
TG_TOPIC_KT=your_topic_id
TG_TOPIC_ST=your_topic_id
TELEGRAM_LIVE_FLIGHT_CHAT_ID=-1003960872491
TELEGRAM_ALERTS_TOPIC_ID=2408
TELEGRAM_REPORTS_TOPIC_ID=2406
# Отчетный квартал ТД — видео на карте (1 ИГ / 2 ИГ / 3 ИГ)
TELEGRAM_VIDEO_REPORTS_CHAT_ID=-1003775039433
TELEGRAM_VIDEO_REPORT_TOPIC_IDS=1036,1038,1040
TELEGRAM_VIDEO_REPORT_SCAN_TO_ID=4400
# Видео на карте: хранение на диске (дни), фоновая догрузка через tg_bot
TELEGRAM_REPORT_VIDEO_RETENTION_DAYS=365
TELEGRAM_VIDEO_SYNC_ENABLED=true
TELEGRAM_VIDEO_SYNC_INTERVAL_SEC=300
TELEGRAM_VIDEO_SYNC_BATCH_SIZE=50
# Local Bot API для видео >20 МБ (https://my.telegram.org → API development tools)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_API_URL=http://telegram-bot-api:8081

# Мост TG ↔ MAX (см. docs/MAX_BRIDGE.md)
MAX_BRIDGE_ENABLED=false
MAX_BOT_TOKEN=
MAX_BRIDGE_CHAT_DIRTY=
MAX_BRIDGE_CHAT_TD=

# Автоимпорт Excel вылетов с NAS-шары (cron 09:00 МСК)
FLIGHTS_EXCEL_IMPORT_DIR=/data/Gerasimenko/ГБУ
FLIGHTS_EXCEL_IMPORT_FILENAME=ТАБ_ПИСЬМЕННОГО_ДОКЛАДА_ПИЛОТОВ_НОВАЯ2.xlsm
DASHBOARD_SHIFT_DAY_START_HOUR=6
DASHBOARD_SHIFT_NIGHT_START_HOUR=18
LIVE_FLIGHT_BOT_SECRET=change_me_to_long_random_string
RUBICON_API_URL=http://api:8000
